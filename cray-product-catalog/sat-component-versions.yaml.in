component_versions:
  docker:
  - name: artifactory.algol60.net/sat-docker/@SAT_REPO_TYPE@/cray-sat
    version: @SAT_VERSION@
  - name: artifactory.algol60.net/sat-docker/@SAT_REPO_TYPE@/sat-install-utility
    version: @SAT_INSTALL_UTILITY_VERSION@
  repositories:
  - name: sat-sle-15sp2
    type: group
    members:
    - sat-@RELEASE_VERSION@-sle-15sp2
  - name: sat-@RELEASE_VERSION@-sle-15sp2
    type: hosted
  rpm:
  - name: cray-sat-podman
    version: @SAT_PODMAN_VERSION@
